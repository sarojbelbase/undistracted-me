{
  "manifest_version": 3,
  "name": "Undistracted Me",
  "version": "3.0.0",
  "author": {
    "email": "mail@sarojbelbase.com.np"
  },
  "description": "Replaces your new tabs with a distraction free nepali date.",
  "icons": {
    "16": "favicon/lotus16.png",
    "32": "favicon/lotus32.png",
    "48": "favicon/lotus48.png",
    "128": "favicon/lotus128.png",
    "512": "favicon/lotus512.png"
  },
  "action": {
    "default_icon": {
      "16": "favicon/lotus16.png",
      "24": "favicon/lotus24.png",
      "32": "favicon/lotus32.png",
      "128": "favicon/lotus128.png"
    },
    "default_title": "New Tab Page",
    "default_popup": "entries/popup.html"
  },
  "background": {
    "service_worker": "src/bg.js"
  },
  "chrome_url_overrides": {
    "newtab": "entries/index.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{1071d037-0f17-4c92-b06c-704050d2e2c3}",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": []
      }
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; object-src 'none';"
  },
  "homepage_url": "https://undistractedme.sarojbelbase.com.np",
  "permissions": [
    "identity",
    "storage",
    "geolocation",
    "topSites",
    "favicon",
    "notifications",
    "alarms",
    "tabs",
    "scripting",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*/*",
    "https://undistractedme.sarojbelbase.com.np/*",
    "https://api.spotify.com/*",
    "https://accounts.spotify.com/*",
    "*://*.youtube.com/*",
    "*://*.soundcloud.com/*",
    "https://nepalipaisa.com/*",
    "https://www.merolagani.com/*",
    "https://people.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://tasks.googleapis.com/*",
    "https://oauth2.googleapis.com/*",
    "https://suggestqueries.google.com/*",
    "https://ac.duckduckgo.com/*",
    "https://api.open-meteo.com/*",
    "https://air-quality-api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://nominatim.openstreetmap.org/*",
    "https://icanhazdadjoke.com/*",
    "https://ipapi.co/*",
    "https://freeipapi.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.soundcloud.com/*",
        "*://*.youtube.com/*"
      ],
      "js": [
        "src/utilities/media.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "entries/blocked.html",
        "assets/blocked*.js",
        "assets/blocked*.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "oauth2": {
    "client_id": "xxxxxxxxxx.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.readonly",
      "https://www.googleapis.com/auth/contacts.readonly",
      "https://www.googleapis.com/auth/tasks",
      "https://www.googleapis.com/auth/userinfo.profile",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  }
}
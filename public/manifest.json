{
  "manifest_version": 3,
  "name": "Undistracted Me",
  "version": "3.0.0",
  "author": "Saroj Belbase",
  "description": "Replaces your new tabs with a distraction free nepali date.",
  "icons": {
    "16": "favicon/lotus16.png",
    "32": "favicon/lotus32.png",
    "48": "favicon/lotus48.png",
    "128": "favicon/lotus128.png",
    "512": "favicon/lotus512.png"
  },
  "action": {
    "default_icon": {
      "16": "favicon/lotus16.png",
      "24": "favicon/lotus24.png",
      "32": "favicon/lotus32.png",
      "128": "favicon/lotus128.png"
    },
    "default_title": "Undistracted Me"
  },
  "background": {
    "service_worker": "src/bg.js"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{1071d037-0f17-4c92-b06c-704050d2e2c3}",
      "strict_min_version": "128.0"
    }
  },
  "homepage_url": "https://whatsthemiti.sarojbelbase.com.np",
  "permissions": [
    "identity",
    "storage",
    "geolocation",
    "topSites",
    "favicon",
    "notifications",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://t1.gstatic.com/*",
    "https://api.spotify.com/*",
    "https://accounts.spotify.com/*",
    "https://nepalipaisa.com/*",
    "https://www.merolagani.com/*",
    "https://people.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://oauth2.googleapis.com/*",
    "https://api.openweathermap.org/*",
    "https://api.unsplash.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.soundcloud.com/*"
      ],
      "js": [
        "src/utilities/media.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "oauth2": {
    "client_id": "647187355675-e5v949u9j2dd54p152rr3l48ulfr4l66.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.readonly",
      "https://www.googleapis.com/auth/contacts.readonly",
      "https://www.googleapis.com/auth/userinfo.profile",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  }
}
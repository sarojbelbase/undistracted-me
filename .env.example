# ─── Vite / Extension build vars (VITE_ prefix → bundled into the client) ──────
# Required for both extension and website builds:
VITE_API_KEY=                # Shared secret: bundled into client (obfuscated via obscureEnvKeys plugin)

# Extension build only (Firefox PKCE OAuth — not needed for website/Vercel):
VITE_GOOGLE_DESKTOP_CLIENT_ID=
VITE_GOOGLE_DESKTOP_CLIENT_SECRET=
VITE_SPOTIFY_CLIENT_ID=      # Spotify OAuth client ID

# Optional overrides:
VITE_WEBSITE_MODE=           # Set to "true" for Vercel website deployment; leave unset for extension
VITE_DEBUG_MODE=             # Set to "true" to enable debug overlays (e.g. Spotify mock)
VITE_PHOTOS_API_URL=         # Override the curated photos endpoint (default: production URL)

# ─── Vercel / Server-side vars (process.env — never bundled into the client) ───
GOOGLE_CLIENT_ID=            # Google OAuth client ID  (used by /api/auth/google/token)
GOOGLE_CLIENT_SECRET=        # Google OAuth client secret (used by /api/auth/google/token)
API_KEY=                     # Same secret as VITE_API_KEY — used by serverless functions (VITE_ vars are build-time only)
BLOB_READ_WRITE_TOKEN=       # Auto-injected by Vercel Blob; needed locally for upload script

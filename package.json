{
	"name": "undistracted-me",
	"version": "3.0.0",
	"description": "A chrome/firefox extension to show distraction free nepali date on your new tab.",
	"main": "index.js",
	"repository": "https://github.com/sarojbelbase/undistracted-me",
	"author": "sarojbelbase",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"test": "playwright test",
		"test:unit": "vitest run --config vitest.config.ts",
		"test:unit:watch": "vitest --config vitest.config.ts",
		"test:unit:coverage": "vitest run --config vitest.config.ts --coverage",
		"test:ui": "playwright test --ui",
		"test:headed": "playwright test --headed",
		"test:report": "playwright show-report tests/playwright/report"
	},
	"dependencies": {
		"dayjs": "^1.11.20",
		"react": "^19.2.4",
		"react-bootstrap-icons": "^1.11.6",
		"react-dom": "^19.2.4",
		"react-grid-layout": "^2.2.3",
		"react-resizable": "^3.1.3",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@crxjs/vite-plugin": "^2.4.0",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/postcss": "^4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.2",
		"autoprefixer": "^10.4.27",
		"jsdom": "^29.0.1",
		"postcss": "^8.5.8",
		"tailwindcss": "^4.2.2",
		"vite": "^8.0.3",
		"vitest": "^4.1.2"
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	}
}
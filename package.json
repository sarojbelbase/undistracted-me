{
	"name": "undistracted-me",
	"version": "3.0.0",
	"description": "A chrome/firefox extension to show distraction free nepali date on your new tab.",
	"main": "index.js",
	"repository": "https://github.com/sarojbelbase/undistracted-me",
	"author": "sarojbelbase",
	"license": "MIT",
	"type": "module",
	"packageManager": "bun@1.3.13",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"start:firefox": "vite build && bun scripts/patch-manifest-firefox.mjs && web-ext run --source-dir ./dist/",
		"build:firefox": "vite build && bun scripts/patch-manifest-firefox.mjs && web-ext build --source-dir ./dist/ --artifacts-dir builds --overwrite-dest",
		"build:chrome": "vite build && zip -r builds/chrome.zip dist",
		"preview": "vite preview",
		"test": "playwright test",
		"test:unit": "vitest run --config vitest.config.ts",
		"test:unit:watch": "vitest --config vitest.config.ts",
		"test:unit:coverage": "vitest run --config vitest.config.ts --coverage",
		"test:ui": "playwright test --ui",
		"test:headed": "playwright test --headed",
		"test:report": "playwright show-report tests/playwright/report"
	},
	"dependencies": {
		"@chenglou/pretext": "^0.0.7",
		"@lexical/code": "^0.44.0",
		"@lexical/history": "^0.44.0",
		"@lexical/link": "^0.44.0",
		"@lexical/list": "^0.44.0",
		"@lexical/markdown": "^0.44.0",
		"@lexical/react": "^0.44.0",
		"@lexical/rich-text": "^0.44.0",
		"@vercel/analytics": "^2.0.1",
		"dayjs": "^1.11.20",
		"lexical": "^0.44.0",
		"react": "^19.2.6",
		"react-bootstrap-icons": "^1.11.6",
		"react-dom": "^19.2.6",
		"react-grid-layout": "^2.2.3",
		"rss-parser": "^3.13.0",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@crxjs/vite-plugin": "^2.4.0",
		"@playwright/test": "^1.60.0",
		"@tailwindcss/postcss": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@vercel/blob": "^2.3.3",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/coverage-v8": "^4.1.6",
		"autoprefixer": "^10.5.0",
		"esbuild": "^0.28.0",
		"jsdom": "^29.1.1",
		"postcss": "^8.5.14",
		"sass": "^1.99.0",
		"tailwindcss": "^4.3.0",
		"vite": "^8.0.13",
		"vitest": "^4.1.6",
		"web-ext": "^10.1.0"
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	}
}
